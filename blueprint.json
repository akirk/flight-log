{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Flight Tracker",
		"description": "A private flight log and statistics app for WordPress.",
		"author": "Alex Kirk",
		"categories": [
			"Apps",
			"Travel"
		]
	},
	"landingPage": "/flight-tracker/",
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/akirk/flight-tracker",
				"ref": "dist/main",
				"refType": "branch"
			},
			"options": {
				"activate": true,
				"targetFolderName": "flight-tracker"
			}
		}
	]
}
